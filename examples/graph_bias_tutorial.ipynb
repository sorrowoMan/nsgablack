    "    for bias in template['biases']:\n",
    "        print(f\"    - {bias['type']} (权重: {bias['weight']})\")\n",
    "\n",
    "# 使用生成树模板\n",
    "spanning_tree_template = GRAPH_BIAS_TEMPLATES['spanning_tree']\n",
    "print(f\"\\n\\n使用 '{spanning_tree_template['description']}' 模板\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5.3 组合多个偏置"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 创建偏置组合\n",
    "biases = [\n",
    "    ConnectivityBias(graph, weight=2.5),  # 强制连通\n",
    "    SparsityBias(graph, target_density=0.2, weight=1.5),  # 控制稀疏性\n",
    "    DegreeDistributionBias(graph, target_degree_pattern=\"uniform\", weight=1.0),  # 均匀度分布\n",
    "    CustomCentralityBias(graph, weight=0.8)  # 自定义中心性偏置\n",
    "]\n",
    "\n",
    "# 计算组合偏置\n",
    "def compute_combined_bias(x, biases, context):\n",
    "    total = 0.0\n",
    "    for bias in biases:\n",
    "        total += bias.compute(x, context)\n",
    "    return total\n",
    "\n",
    "combined_value = compute_combined_bias(solution, biases, context)\n",
    "print(f\"组合偏置值: {combined_value:.3f}\")\n",
    "\n",
    "print(\"\\n各个偏置的贡献:\")\n",
    "for bias in biases:\n",
    "    value = bias.compute(solution, context)\n",
    "    print(f\"  {bias.name}: {value:.3f}\")"
   ]
