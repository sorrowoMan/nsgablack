    "# 图偏置系统教程\n",
    "\n",
    "本教程介绍如何使用图偏置系统来解决各种图论优化问题。\n",
    "\n",
    "## 目录\n",
    "1. [图偏置基础](#1-图偏置基础)\n",
    "2. [创建图结构](#2-创建图结构)\n",
    "3. [使用预定义偏置](#3-使用预定义偏置)\n",
    "4. [自定义偏置](#4-自定义偏置)\n",
    "5. [解决具体问题](#5-解决具体问题)\n",
    "\n",
    "---"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. 图偏置基础\n",
    "\n",
    "图偏置系统提供了将图论问题的结构特性编码到优化算法中的能力。主要包括：\n",
    "\n",
    "- **GraphStructure**: 图的数据表示\n",
    "- **GraphUtils**: 图操作工具类\n",
    "- **各种图偏置**: 针对不同图论问题的专用偏置\n",
    "- **GraphBiasFactory**: 偏置创建工厂"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 导入必要的库\n",
    "import numpy as np\n",
    "import networkx as nx\n",
    "import matplotlib.pyplot as plt\n",
    "from typing import List, Tuple\n",
    "\n",
    "# 导入图偏置系统\n",
    "from bias import (\n",
    "    GraphStructure, GraphUtils, GraphBiasFactory,\n",
    "    ConnectivityBias, SparsityBias, DegreeDistributionBias,\n",
    "    ShortestPathBias, GraphColoringBias, CommunityDetectionBias\n",
    ")\n",
    "\n",
    "print(\"图偏置系统导入成功！\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. 创建图结构\n",
    "\n",
    "GraphStructure类支持多种图表示方式："
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 方法1：使用边列表创建图\n",
    "edge_list = [\n",
    "    (0, 1, 2.5), (0, 2, 1.8), (1, 2, 3.2),\n",
    "    (1, 3, 1.5), (2, 3, 2.0), (3, 4, 1.2),\n",
    "    (4, 5, 2.8), (5, 6, 1.9), (6, 7, 2.2),\n",
    "    (7, 0, 3.5)\n",
    "]\n",
    "\n",
    "graph = GraphStructure(\n",
    "    num_nodes=8,\n",
    "    num_edges=len(edge_list),\n",
    "    directed=False,\n",
    "    weighted=True,\n",
    "    edge_list=edge_list\n",
    ")\n",
    "\n",
    "print(f\"创建了有 {graph.num_nodes} 个节点和 {graph.num_edges} 条边的图\")\n",
    "print(f\"邻接矩阵形状: {graph.adjacency_matrix.shape}\")\n",
    "\n",
    "# 可视化图\n",
    "G = nx.Graph()\n",
    "G.add_weighted_edges_from(edge_list)\n",
    "\n",
    "plt.figure(figsize=(8, 6))\n",
    "pos = nx.spring_layout(G)\n",
    "nx.draw(G, pos, with_labels=True, node_color='lightblue', \n",
    "        node_size=500, font_weight='bold')\n",
    "edge_labels = nx.get_edge_attributes(G, 'weight')\n",
    "nx.draw_networkx_edge_labels(G, pos, edge_labels=edge_labels)\n",
    "plt.title(\"示例图\")\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. 使用预定义偏置\n",
    "\n",
    "图偏置系统提供了多种预定义的偏置类型："
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 创建不同的偏置实例\n",
    "\n",
    "# 1. 连通性偏置 - 确保子图是连通的\n",
    "connectivity_bias = ConnectivityBias(graph, weight=3.0)\n",
    "print(f\"连通性偏置: {connectivity_bias.name}\")\n",
    "\n",
    "# 2. 稀疏性偏置 - 控制边的密度\n",
    "sparsity_bias = SparsityBias(graph, target_density=0.3, weight=2.0)\n",
    "print(f\"稀疏性偏置目标密度: {sparsity_bias.target_density}\")\n",
    "\n",
    "# 3. 度分布偏置 - 鼓励特定的度分布模式\n",
    "degree_bias = DegreeDistributionBias(\n",
    "    graph, target_degree_pattern=\"scale_free\", weight=1.5\n",
    ")\n",
    "print(f\"度分布偏置模式: {degree_bias.target_pattern}\")\n",
    "\n",
    "# 计算图的性质\n",
    "graph_props = GraphUtils.compute_graph_properties(graph)\n",
    "print(\"\\n图的性质:\")\n",
    "for prop, value in graph_props.items():\n",
    "    print(f\"  {prop}: {value:.3f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 3.1 偏置工作原理演示"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 创建一个解向量（表示选择哪些边）\n",
    "solution = np.array([1, 1, 0, 1, 0, 1, 0, 1, 1, 0])  # 选择前3条边、第4条边等\n",
    "\n",
    "# 创建模拟的优化上下文\n",
    "from bias_base import OptimizationContext\n",
    "context = OptimizationContext(\n",
    "    generation=50,\n",
    "    population_size=100,\n",
    "    current_objective=10.0\n",
    ")\n",
    "\n",
    "# 计算各个偏置的值\n",
    "print(\"偏置计算结果:\")\n",
    "print(f\"连通性偏置值: {connectivity_bias.compute(solution, context):.3f}\")\n",
    "print(f\"稀疏性偏置值: {sparsity_bias.compute(solution, context):.3f}\")\n",
    "print(f\"度分布偏置值: {degree_bias.compute(solution, context):.3f}\")\n",
    "\n",
    "# 查看解对应的子图\n",
    "subgraph = GraphUtils.extract_subgraph(solution, graph)\n",
    "print(f\"\\n解对应的子图:\")\n",
    "print(f\"  边数: {subgraph.num_edges}\")\n",
    "print(f\"  边列表: {subgraph.edge_list}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. 自定义偏置\n",
    "\n",
    "您可以通过继承GraphBias类来创建自定义偏置："
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from bias.bias_base import DomainBias\n",
    "\n",
    "class CustomCentralityBias(GraphBias):\n",
    "    \"\"\"自定义偏置：鼓励选择与高中心性节点相连的边\"\"\"\n",
    "    \n",
    "    def __init__(self, graph: GraphStructure, weight: float = 1.0):\n",
    "        super().__init__(\"centrality\", graph, weight)\n",
    "        # 预计算节点中心性\n",
    "        if graph.adjacency_matrix is not None:\n",
    "            G = nx.Graph()\n",
    "            for i in range(graph.num_nodes):\n",
    "                for j in range(i + 1, graph.num_nodes):\n",
    "                    if graph.adjacency_matrix[i, j] > 0:\n",
    "                        G.add_edge(i, j, weight=graph.adjacency_matrix[i, j])\n",
    "            self.centralities = nx.betweenness_centrality(G, weight='weight')\n",
    "        else:\n",
    "            self.centralities = {i: 0.0 for i in range(graph.num_nodes)}\n",
    "    \n",
    "    def compute(self, x: np.ndarray, context: OptimizationContext) -> float:\n",
    "        subgraph = self.encode_solution_to_graph(x)\n",
    "        \n",
    "        if not subgraph.edge_list:\n",
    "            return -self.weight * 10.0\n",
    "        \n",
    "        # 计算选中边的平均中心性\n",
    "        total_centrality = 0.0\n",
    "        edge_count = 0\n",
    "        \n",
    "        for u, v, _ in subgraph.edge_list:\n",
    "            total_centrality += self.centralities[u] + self.centralities[v]\n",
    "            edge_count += 1\n",
    "        \n",
    "        avg_centrality = total_centrality / (2 * edge_count) if edge_count > 0 else 0\n",
    "        \n",
    "        # 奖励高中心性\n",
    "        return self.weight * avg_centrality\n",
    "\n",
    "# 使用自定义偏置\n",
    "custom_bias = CustomCentralityBias(graph, weight=2.0)\n",
    "custom_value = custom_bias.compute(solution, context)\n",
    "print(f\"自定义中心性偏置值: {custom_value:.3f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. 解决具体问题\n",
    "\n,
    "### 5.1 最大流问题"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 创建一个流网络\n",
    "flow_edges = [\n",
    "    (0, 1, 10), (0, 2, 10), (1, 2, 2),\n",
    "    (1, 3, 4), (1, 4, 8), (2, 4, 9),\n",
    "    (3, 4, 6), (3, 5, 10), (4, 5, 10)\n",
    "]\n",
    "\n",
    "flow_graph = GraphStructure(\n",
    "    num_nodes=6,\n",
    "    num_edges=len(flow_edges),\n",
    "    directed=True,\n",
    "    weighted=True,\n",
    "    edge_list=flow_edges\n",
    ")\n",
    "\n",
    "# 创建最大流偏置\n",
    "maxflow_bias = MaxFlowBias(flow_graph, source=0, sink=5, weight=3.0)\n",
    "\n",
    "# 模拟一个解（选择所有边）\n",
    "flow_solution = np.ones(len(flow_edges))\n",
    "\n",
    "print(f\"最大流偏置值: {maxflow_bias.compute(flow_solution, context):.3f}\")\n",
    "\n",
    "# 使用NetworkX验证最大流\n",
    "G = nx.DiGraph()\n",
    "for u, v, cap in flow_edges:\n",
    "    G.add_edge(u, v, capacity=cap)\n",
    "\n",
    "flow_value, flow_dict = nx.maximum_flow(G, 0, 5)\n",
    "print(f\"实际最大流值: {flow_value}\")"
   ]
  },
  {
   "cell_type": "markdown",
